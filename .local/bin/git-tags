#!/usr/bin/env bash

(return 0 2>/dev/null) && SOURCED=1 || SOURCED=0
if [[ ${SOURCED} == 1 ]]; then
  printf "\033[1;95mFatal: Do not source %s\033[0m\n" "$0"
  FATAL
fi

function Git_tags()
{
  local HELP_TEXT='
NAME
----

git-tags - display a list of git tags

SYNOPSIS
--------

```bash
git-tags --help
git-tags [-#]
```
'
  export ERRORS=0
  local VERSION=1.0.0 N=10

  # Parse command-line
  while [[ "$1" =~ ^- ]]; do
    local OPT="$1"
    shift
    if [[ "${OPT}" =~ ^-{1,2}h(elp)?$ ]]; then
      if command -v glow 2>/dev/null; then
        glow -p <<<"${HELP_TEXT}" #>>>
      else
        echo "${HELP_TEXT}"
      fi
      return 0
    elif [[ "${OPT}" =~ ^-{1,2}[Vv](ersion)?$ ]]; then
      echo "${0/*\//} version ${VERSION}"
      return 0
    elif [[ "${OPT}" =~ ^-[1-9][0-9]*$ ]]; then
      (( N=-${OPT} ))
    else
      Report_error "Unknown option: ${OPT}"
    fi
  done

  # shellcheck disable=SC2312
  git for-each-ref --count=30 \
                   --sort='-*authordate' \
                   --format='%(*objectname:short) %(*refname) %(*authorname) %(*subject) %(*authordate)' \
                   refs/tags/* \
    | perl -pe 's-refs/tags/--;s{... }{  };s{.[{][}]}{};' \
    | head -n "${N}"
}

function Report_error()
{
  export ERRORS
  (( ++ERRORS ))
  local RED="[1;91m" OFF="[0m"
  echo "${RED}Error:${OFF} $*"
}

Git_tags "$@"
