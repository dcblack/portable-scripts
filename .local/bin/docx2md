#!/usr/bin/env bash
#
#$Info: docx2md - Convert Word to Markdown. $

function Realpath ()
{
  /usr/bin/perl '-MCwd(abs_path)' -le '$p=abs_path(join(q( ),@ARGV));print $p if -e $p' "$*"
}

# Using Essential-IO
SCRIPTDIR="$(Realpath "$(dirname "$0")"/../scripts)"
if [[ ! -r "${SCRIPTDIR}/Essential-IO" ]]; then
  SCRIPTDIR="$(Realpath "${HOME}"/.local/scripts)"
fi
if [[ ! -r "${SCRIPTDIR}/Essential-IO" ]]; then
  SCRIPTDIR="$(Realpath "$(dirname "$0")")"
fi
if [[ ! -r "${SCRIPTDIR}/Essential-IO" ]]; then
  printf "FATAL: Missing required source file '%s'\n" "${SCRIPTDIR}/Essential-IO"
  crash
fi
# shellcheck disable=SC2250,SC1091
source "$SCRIPTDIR/Essential-IO"

function Docx_to_md()
{
  local HELP_TEXT
  #shellcheck disable=SC2016
  HELP_TEXT='
Name
----

docx2md - Convert Word documents to Markdown

Synopsis
--------

```bash
docx2md --help|-h # produces this text
docx2md [OPTIONS] FILE_OR_DIRECTORY_LIST
```

Description
-----------

For every file specified or within a specified directory, convert files ending with the `.docx` extension to markdown using the `.md` extension.

Only converts files that end with `.docx` and do not already have a corresponding `.md` file.

Options
-------

Option    | Alt  | Action
------    | ---  | ------
--help    | -h   | Display this help text
--depth=N | -d N | specify search depth for directories (defaults to 1)
--force   | -f   | Overwrite pre-exising file
--keep    | -k   | Keep original filename (i.e., do not make linux friendly)
--quiet   | -q   | Minimal output
--verbose | -v   | Verbose output
--nah     | -n   | Not really (implies verbose)

Dependency
----------

pandoc is required

Examples
--------

```bash
docx2md .
docx2md file1.docx file2.docx mydir/docs
```

'

  local ARG FILES=() FILE MD FORCE=0 VERBOSE=0 KEEP=0 NAH=0

  if [[ $# == 0 ]]; then
    Report_warning "Must specify at least one file or directory. Use --help for more information."
  fi

  export ERRORS=0
  local FILES=()
  local DEPTH=1
  while [[ $# -gt 0 ]]; do
    local ARG="$1"
    if [[ "${ARG}" =~ ^- ]]; then
      case "${ARG}" in
        -h|-help|--help)
          if builtin command -v glow; then
            glow -p <<<"${HELP_TEXT}" #>>>
          else
            echo "${HELP_TEXT}"
          fi
          return 0
          ;;
        -d|--depth=*)
          if [[ "${ARG}" == '-d' ]]; then
            if [[ "$2" =~ ^[1-9][0-9]*$ ]]; then
              DEPTH="$2"
              shift
            else
              Report_error "Depth must be a positive number"
            fi
          else
            local N="${ARG}"
            N="${N#--depth=}"
            if [[ "${N}" =~ ^[0-9]+$ ]]; then
              DEPTH="${N}"
            else
              Report_error "Depth '${N}' must be a positive number"
            fi
          fi
          ;;
        -f|--force)
          FORCE=1
          ;;
        -k|--keep)
          KEEP=1
          ;;
        -n|--not_really)
          NAH=1
          VERBOSE=1
          ;;
        -q|--quiet)
          VERBOSE=0
          ;;
        -v|--verbose)
          VERBOSE=1
          ;;
        *)
          Report_error "Unknown option '${ARG}'"
          ;;
      esac
    elif [[ -d "${ARG}/." ]]; then
      #shellcheck disable=SC2312
      mapfile -t -O "${#FILES[@]}" FILES < <(find . -depth "${DEPTH}" -name '*.docx' -print0 | xargs -0 printf '%s\n')
    elif [[ -r "${ARG}" ]]; then
      if [[ "${ARG}" =~ .*[.]docx ]]; then
        FILES+=( "${ARG}" )
      else
        Report_warning "Skipping '${ARG}' - not Microsoft Word docx"
      fi
    else
      Report_warning "Skipping '${ARG}' - not a file or directory"
    fi
    shift
  done
  if [[ ${ERRORS} -gt 0 ]]; then
    Report_info "Please fix and retry"
    return 1
  fi

  for FILE in "${FILES[@]}"; do
    if [[ "${FILE}" =~ .*[.]docx ]]; then
      MD="${FILE/.docx/.md}"
      if [[ ${KEEP} == 0 ]]; then
        MD=$(sed -E 's/[_$%@# ]+/_/g' <<<"${MD}") #>>>
        Report_debug "converted to '${MD}'"
      fi
    else
      Report_warning "Skipping '${FILE}' - not Microsoft Word docx"
      continue
    fi
    if [[ -r "${MD}" && ${FORCE} == 1 ]]; then
      Report_info -f "Existing ${MD}"
    else
      if [[ ${VERBOSE} == 1 ]]; then
        _do -n "pandoc -f docx -t gfm '${FILE}' -o '${MD}'"
      fi
      if [[ ${NAH} == 1 ]]; then
        continue
      fi
      pandoc -f docx -t gfm "${FILE}" -o "${MD}"
      Report_info -f "Created  '${MD}'"
    fi
  done
}

Docx_to_md "$@"

