#!/usr/bin/env bash
#
#$Info: tool-versions - displays version information for selected development tools. $
#
# Runtime requirements are checked after option parsing.  macOS uses the GNU
# utilities installed by Homebrew because BSD sort does not support -z.

export CC CXX
TOOL_NAME="${0##*/}"
TOOL_VERS=1.3.1

function Tool_versions()
{
  # Defaults
  local EXTRA QUIET SORT
  local -a TOOLS EXTRAS
  export NOCOLOR CXX CC
  EXTRA=0
  QUIET=0
  SORT=1
  TOOLS=()
  # Color support
  local CRED="" CGRN="" CYLW="" CBLU="" CMAG="" CCYN="" BOLD="" NONE=""
  if [[ "${NOCOLOR}" != 1 ]]; then
    # shellcheck disable=SC2034
    CRED="[91m" CGRN="[92m" CYLW="[93m" CBLU="[94m" CMAG="[95m" CCYN="[96m" BOLD="[1m" NONE="[0m"
  fi
  while [[ $# != 0 ]]; do
    case "$1" in
      -h|--help)
        if [[ $# != 1 ]]; then
          echo "Error: --help must be the only option" >&2
          exit 1
        fi
        cat <<EOT
NAME
----

  ${TOOL_NAME} - Display the versions of tools

SYNOPSIS
--------

  ${TOOL_NAME} -h|--help
  ${TOOL_NAME} -V|--version
  ${TOOL_NAME} [OPTIONS] [TOOL...]

DESCRIPTION
-----------

This script is useful to produce a quick list of tools in your environment. You can use when creating a bug report or when creating information about how something was tested.

OPTIONS
-------

| OPTION    | SHORT | DESCRIPTION                        |
| :-----    | :---: | :----------                        |
| --color   |  -C   | Use color (default)                |
| --extras  |  -x   | Show extra tools                   |
| --help    |  -h   | Display this help                  |
| --loud    |  -l   | Yell about missing tools (default) |
| --no-color, --nocolor |  -N   | No color                    |
| --quiet   |  -q   | Don't complain about missing tools |
| --no-sort |  -n   | Do not sort the tool list          |
| --sort    |  -s   | Sort the tool list (default)       |
| --version |  -V   | Show version of this script        |

DEPENDENCIES
------------

- Bash: required to interpret this script; Bash 3.2 or newer is supported.
- date: required for the host-information timestamp.
- Perl (perl or perl5): required to parse Linux distribution information and
  filter tool version output.
- uname (guname on macOS): required for host information.
- sort (gsort on macOS): GNU sort is required because the script uses -z.
- sw_vers: required on macOS for the operating-system version.
- The commands listed in the default and --extras tool lists are optional
  targets; missing targets are reported unless --quiet is selected.

CONFLICTS AND PLATFORM NOTES
----------------------------

- macOS ships BSD sort and BSD utilities. If Homebrew is not installed, use
  /bin/bash -c "\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)".
  Then install GNU dependencies with: brew install coreutils gnu-sed gnu-tar
  perl. Ensure Homebrew's bin directory is in PATH (brew shellenv can do this).
- On macOS, coreutils supplies gsort and guname, while gnu-sed and gnu-tar
  supply gsed and gtar. The script deliberately prefers these names.
- Ubuntu and other GNU/Linux systems normally provide the required utilities;
  minimal installations may need packages such as perl and coreutils.
- WSL is supported when wsl.exe is visible in PATH; it is optional and only
  adds a WSL host label.
- MinGW/MSYS/Cygwin Bash environments may have different tool names and
  version-output formats. The script does not require Windows tools, but the
  requested development tools must be available in PATH.
- Tool version output is filtered by tool-specific patterns, so vendor or
  localized output can be omitted even when a command succeeds.

EOT
        exit 0
        ;;
      -x|--extras)   EXTRA=1 ;;
      -C|--color)    NOCOLOR=0 CRED="[91m" CGRN="[92m" BOLD="[1m" NONE="[0m" ;;
      -l|--loud)     QUIET=0 ;;
      -N|--no-color|--nocolor) NOCOLOR=1 CRED="" CGRN="" BOLD="" NONE="" ;;
      -n|--no-sort)  SORT=0 ;;
      -q|--quiet)    QUIET=1 ;;
      -s|--sort)     SORT=1 ;;
      -V|--version)
        if [[ $# != 1 ]]; then
          echo "Error: --version must be the only option" >&2
          exit 1
        fi
        echo "${TOOL_NAME} version ${TOOL_VERS}"
        exit 0
        ;;
      -*)            echo "Error: Unknown option: $1" >&2; exit 1 ;;
       *)            TOOLS+=("$1") ;;
    esac
    shift
  done

  local PERL5 PYTHON3 SED TAR UNAME SORT_COMMAND
  PERL5="perl"
  # shellcheck disable=SC2312
  if [[ -n "$(builtin command -v perl5 )" ]]; then
    PERL5="perl5"
  fi
  if ! builtin command -v "${PERL5}" >/dev/null 2>&1; then
    PERL5="perl5"
  fi
  # Python 3 may be installed as either `python3` or `python`; verify the
  # selected command's version output when it is reported below.
  PYTHON3="python"
  # shellcheck disable=SC2312
  if [[ -n "$(builtin command -v python3 )" ]]; then
    PYTHON3="python3"
  fi
  SED="sed"
  # shellcheck disable=SC2312
  if [[ -n "$(builtin command -v gsed )" ]]; then
    SED="gsed"
  fi
  TAR="tar"
  # shellcheck disable=SC2312
  if [[ -n "$(builtin command -v gtar )" ]]; then
    TAR="gtar"
  fi
  UNAME="uname"
  # shellcheck disable=SC2312
  if [[ -n "$(builtin command -v guname )" ]]; then
    UNAME="guname"
  fi
  if ! builtin command -v "${UNAME}" >/dev/null 2>&1; then
    echo "Error: Missing required dependency: ${UNAME}" >&2
    return 1
  fi
  local HOSTOS
  HOSTOS="$("${UNAME}" -s 2>/dev/null)"
  if [[ -z "${HOSTOS}" ]]; then
    echo "Error: Unable to determine the host operating system" >&2
    return 1
  fi
  SORT_COMMAND="sort"
  if [[ "${HOSTOS}" == "Darwin" ]]; then
    # BSD sort lacks -z; Homebrew coreutils installs the compatible command
    # under the non-conflicting name gsort.
    SORT_COMMAND="gsort"
  fi

  # Check the commands that the script itself, rather than a listed target,
  # must execute.  Do this before producing output to avoid partial reports.
  local REQUIRED_COMMAND
  for REQUIRED_COMMAND in date "${PERL5}" "${SORT_COMMAND}"; do
    if ! builtin command -v "${REQUIRED_COMMAND}" >/dev/null 2>&1; then
      echo "Error: Missing required dependency: ${REQUIRED_COMMAND}" >&2
      if [[ "${REQUIRED_COMMAND}" == "gsort" ]]; then
        echo "Install it on macOS with: brew install coreutils" >&2
      fi
      return 1
    fi
  done

  # Check macOS-only dependencies before producing any report output.
  if [[ "${HOSTOS}" == "Darwin" ]] && ! builtin command -v sw_vers >/dev/null 2>&1; then
    echo "Error: Missing required dependency: sw_vers" >&2
    return 1
  fi

      
  # Default tools
  if [[ "${#TOOLS[@]}" == 0 ]]; then
    TOOLS=(
      autoconf
      bash
      cargo
      clang++
      cmake
      g++
      gdb
      git
      gmake
      grep
      lldb
      make
      ninja
      "${PERL5}"
      "${PYTHON3}"
      rustc
      rustup
      systemc-version
    )
  fi
  EXTRAS=(
    ag 
    build
    clang-format
    clang-tidy
    croc
    find_extern
    gh
    gtree
    gzip
    marktext
    rg
    rsync
    shellcheck
    "${SED}"
    "${TAR}"
    tree
    "${UNAME}"
    unzip
    zip
    zsh
  )

  if [[ ${EXTRA} == 1 ]]; then
    TOOLS+=( "${EXTRAS[@]}" )
  fi

  #-------------------------------------------------------------------------------
  # Filters
  #-------------------------------------------------------------------------------
  local FILTER_OUT
  FILTER_OUT='AUTHORS'
  FILTER_OUT+='|Capabilities'
  FILTER_OUT+='|Copyright'
  FILTER_OUT+='|Features'
  FILTER_OUT+='|free.software'
  FILTER_OUT+='|internal'
  FILTER_OUT+='|Install'
  FILTER_OUT+='|License'
  FILTER_OUT+='|Licence'
  FILTER_OUT+='|licenses'
  FILTER_OUT+='|lzma'
  FILTER_OUT+='|maintained'
  FILTER_OUT+='|Packaged by Debian'
  FILTER_OUT+='|rsync.samba'
  FILTER_OUT+='|rsync version'
  FILTER_OUT+='|ShellCheck'
  FILTER_OUT+='|Swift'
  FILTER_OUT+='|There'
  FILTER_OUT+='|Thread'
  FILTER_OUT+='|Target'
  FILTER_OUT+='|website'
  FILTER_OUT+='|welcome'
  FILTER_OUT+='|Written'

  echo "----------------------------------------"
  export NODATE
  if [[ -z "${NODATE}" ]]; then
    date
  fi

  #-------------------------------------------------------------------------------
  # Announce the Host information
  #-------------------------------------------------------------------------------
  local OS PERLSCRIPT
  case "${HOSTOS}" in
    Darwin)
      "${UNAME}" -moprv
      OS="$(sw_vers --productName) "
      OS+="$(sw_vers --productVersion)"
      OS+="$(sw_vers --productVersionExtra) "
      OS+="$(sw_vers --buildVersion) "
      echo "${OS}"
      ;;
    *)
      "${UNAME}" -smoprv
      # shellcheck disable=SC2312
      if [[ -n "$(builtin command -v wsl.exe )" ]]; then
        echo -n "WSL "
      fi
      if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC2034,SC2016
        PERLSCRIPT='if(m{PRETTY_NAME="([^"]+)"}){$os=$1;$os=~s{Oracle}{CentOS};print $os;}'
        "${PERL5}" -lne "${PERLSCRIPT}" /etc/os-release
      fi
      ;;
  esac

  echo "........................................"

  #-------------------------------------------------------------------------------
  # Sort
  #-------------------------------------------------------------------------------
  if [[ ${SORT} == 1 ]]; then
    local -a SORTED=()
    local ELEMENT
    # shellcheck disable=SC2312
    while IFS= read -r -d '' ELEMENT; do
        SORTED+=("${ELEMENT}")
    done < <(printf '%s\0' "${TOOLS[@]}" | "${SORT_COMMAND}" -z)
    TOOLS=("${SORTED[@]}")   
  fi

  #-------------------------------------------------------------------------------
  # Display each of the tools
  #-------------------------------------------------------------------------------
  local TOOL EXISTS PATTERN SUBST VERSION_OPTION
  for TOOL in "${TOOLS[@]}"; do
    VERSION_OPTION=--version
    EXISTS="$(builtin command -v "${TOOL}")"
    PATTERN=""
    SUBST="s/This is perl/Perl/"
    if [[ -n "${EXISTS}" ]]; then
      case "${TOOL}" in
        ag)    PATTERN="ag version" ;;
        bash)  PATTERN="${TOOL}" ;;
        build) PATTERN="build version" ;;
        clang-tidy) PATTERN="version" ;;
        clang-format) PATTERN="version" ;;
        clang) PATTERN="${TOOL}" ;;
        g[+][+]) PATTERN="${TOOL}" ;;
        git)   PATTERN="version" ;;
        gmake) PATTERN="Make" ;;
        gsed)  PATTERN="[(]GNU sed[)]" ;;
        gzip)  PATTERN="gzip" ;;
        make)  PATTERN="Make" ;;
        perl)  PATTERN="version" ;;
        python|python3) PATTERN="Python 3" ;;
        rg)    PATTERN="ripgrep" ;;
        rsync) PATTERN="version" ;;
        sed)   PATTERN="[(]GNU sed[)]" ;;
        shellcheck) PATTERN="version" ;;
        tar)   PATTERN="bsdtar" ;;
        unzip) PATTERN="modifications" VERSION_OPTION=-v ;;
        zip)   PATTERN="This is " SUBST="s/This is //" ;;
        zsh)   PATTERN="${TOOL}" ;;
        *)     PATTERN+="" ;;
      esac
      echo -n "${CGRN}${TOOL}${NONE} - "
      # Buffer each command so a failed version probe can be distinguished
      # from a valid command whose output simply has no matching filter.
      local VERSION_OUTPUT VERSION_STATUS
      VERSION_OUTPUT="$("${TOOL}" "${VERSION_OPTION}" 2>&1)"
      VERSION_STATUS=$?
      if [[ ${VERSION_STATUS} != 0 ]]; then
        echo "${CRED}${TOOL} - ${BOLD}FAILED${NONE}"
        continue
      fi
      # A command named `python` is acceptable only when it identifies as
      # Python 3; this catches legacy Python 2 installations explicitly.
      if [[ "${TOOL}" == "python" || "${TOOL}" == "python3" ]] &&
        [[ ! "${VERSION_OUTPUT}" =~ Python[[:space:]]3 ]]; then
        echo "${CRED}${TOOL} - ${BOLD}FAILED (Python 3 required)${NONE}"
        continue
      fi
      printf '%s\n' "${VERSION_OUTPUT}" \
        | "${PERL5}" -ne "next unless m/${PATTERN}/; next if m/(${FILTER_OUT})/ or m/^$/; ${SUBST}; print"
    elif [[ ${QUIET} != 1 ]]; then
      echo "${CRED}${TOOL} - ${BOLD}MISSING${NONE}"
    fi
  done
  if [[ -n "${CXX}" ]]; then
    echo "${CCYN}export CXX=${CXX}${NONE}"
  fi
  if [[ -n "${CC}" ]]; then
    echo "${CCYN}export CC=${CC}${NONE}"
  fi

  echo "----------------------------------------"
  if [[ ${EXTRA} == 0 ]]; then
    echo "${CCYN}HINT: For more tools use --extras${NONE}"
  fi
}

Tool_versions "$@"

# vim:nospell
