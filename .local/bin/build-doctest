#!/usr/bin/env bash
#

export VERBOSITY
VERSION=1.1
while [[ "$1" =~ ^- ]]; do
  case "$1" in
    -h|-help|--help)
      cat <<'HELPTEXT'
Name
----
build-doctest - Install doctest under current project.

Synopsis
--------
build-doctest --help|-h # produces this text
build-doctest [-v|-q]

Description
-----------
Installs under the directory `extern/include` and extern/lib, which is located based on the top-level extern/include location.

IMPORTANT
---------
Must be run inside project git repository.

HELPTEXT
      exit 0;
      ;;
    -q|--quiet)
      VERBOSITY=0
      ;;
    -v|--verbose)
      VERBOSITY=1
      ;;
    --version|-version)
      echo "build-doctest version ${VERSION}"
      exit 0
      ;;
    *)
      ;;
  esac
  shift
done

TOOL_NAME="doctest"
TOOL_DESC="${TOOL_NAME} library"
GIT_URL="https://github.com/doctest/doctest.git"
HEADERS=( "doctest" )

function Realpath() {
  if [[ $# == 0 ]]; then set - .; fi
  /usr/bin/perl '-MCwd(abs_path)' -le '$p=abs_path(join(q( ),@ARGV));print $p if -e $p' "$*"
}

# Using Essential-IO
SCRIPTDIR="$(Realpath "$(dirname "$0")"/../scripts)"
if [[ ! -r "${SCRIPTDIR}/Essential-IO" ]]; then
  SCRIPTDIR="$(Realpath ~/.local/scripts)"
fi
if [[ ! -r "${SCRIPTDIR}/Essential-IO" ]]; then
  SCRIPTDIR="$(Realpath "$(dirname "$0")")"
fi
if [[ ! -r "${SCRIPTDIR}/Essential-IO" ]]; then
  printf "FATAL: Missing required source file '%s'\n" "${SCRIPTDIR}/Essential-IO"
  crash
fi
# shellcheck disable=SC2250,SC1091
source "$SCRIPTDIR/Essential-IO"

# TOOL_PATH REPO_DIR INSTALL_DIR
#
TOOL_PATH="$(Realpath "$0")"
Report_info "Attempting to build ${TOOL_DESC} using ${TOOL_PATH}"
INSTALL_DIR="$(find_extern -s)"
if [[ -z "${INSTALL_DIR}" ]]; then
  Report_fatal "Unable to locate required extern/include directory";
  return 1
fi
REPO_DIR="$(basename "${GIT_URL}" .git)"
BUILD_DIR="BUILD-${TOOL_NAME}"
_do mkdir -p "${INSTALL_DIR}"
_do cd "${INSTALL_DIR}" || Report_fatal "Unable to enter ${INSTALL_DIR}"
Report_info "Building under ${INSTALL_DIR}"
if [[ -d "${REPO_DIR}/.git" ]]; then
  _do git -C "${REPO_DIR}" pull
  Report_info "Successfully updated ${TOOL_DESC}"
else
  _do rm -fr "${REPO_DIR}"
  _do git clone "${GIT_URL}" || Report_fatal "Unable to clone"
  Report_info "Successfully installed ${TOOL_DESC}"
fi
cd "${REPO_DIR}" || Report_fatal "Unable to enter ${REPO_DIR}"
declare -a FILES
FILES=()
for HEADER in "${HEADERS[@]}"; do
  FILES+=( "${HEADER}" )
done
_do rsync -av "${FILES[@]}" "${INSTALL_DIR}/include/" || Report_fatal "Unable to install"
Report_info "Successfully built ${TOOL_DESC}"

# vim:nospell
