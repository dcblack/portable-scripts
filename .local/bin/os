#!/usr/bin/env bash
#
# os - display the operating system name.
readonly OS_VERSION="0.2.1"

if [[ $# == 1 && "$1" =~ ^-{1,2}h(elp)?$ ]]; then
  cat <<'HELPTEXT'
Name
----
os - display the operating system name.

Synopsis
--------
os --help|-h
os --version|-V
os [-1|-v] [-p|--platform]

Description
-----------
Displays information about the operating system.

Options
-------

Flag | Description
---- | -----------
-1   | Succinct one-line output
-p   | Indicate platform (macOS|CoCalc|WSL|MinGW)
-v   | Verbose
-V, --version | Display the version and exit

Dependencies
------------

- Bash: required to interpret the script.
- uname: required for every invocation that reports the operating system.
- Perl: required on Linux when /etc/os-release is available; it parses the
  distribution name. It is not required on macOS or MinGW for normal output.
- cat: required by verbose Linux output.
- sw_vers: required by verbose macOS output.
- WSL: wsl.exe is optional and is used only to identify a WSL environment.
- CoCalc: /cocalc/bin/cocalc-open is optional and is used only to identify
  a CoCalc environment.
- MinGW: the script uses the MinGW/MSYS uname implementation; no separate
  MinGW executable is invoked.

Conflicts
---------

- Ubuntu/Linux normally provides uname, Perl, and cat, but minimal images may
  omit Perl or cat. /etc/os-release is Linux-specific.
- macOS provides uname and sw_vers, but does not normally provide
  /etc/os-release. Perl availability varies by macOS installation.
- WSL depends on the Windows-side wsl.exe being visible in PATH; native Linux
  systems do not need it.
- CoCalc detection depends on the optional /cocalc/bin/cocalc-open marker and
  is not available on ordinary Ubuntu or macOS installations.
- MinGW/MSYS supplies Unix-like commands with Windows path and uname values;
  macOS-only sw_vers and Linux-only /etc/os-release are unavailable.

HELPTEXT
  exit 0;
fi

if [[ $# == 1 && ( "$1" =~ ^-{1,2}version$ || "$1" == "-V" ) ]]; then
  printf "os Version %s\n" "${OS_VERSION}"
  exit 0
fi

function Report_error()
{
  printf 'Error: %s\n' "$*" >&2
  return 1
}

function Require_command()
{
  if ! builtin command -v "$1" >/dev/null 2>&1; then
    Report_error "Missing required dependency: $1"
    return 1
  fi
  return 0
}

function Run_command()
{
  local OUTPUT STATUS
  OUTPUT="$("$@")"
  STATUS=$?
  if [[ ${STATUS} != 0 ]]; then
    Report_error "'$*' failed"
    return "${STATUS}"
  fi
  printf '%s\n' "${OUTPUT}"
}

function Os_main()
{
  # Parse command options
  local VERBOSE=0 SUCCINCT=0 PLATFORM=0
  local OS KERNEL_OS
  while [[ $# -gt 0 ]]; do
    if [[ "$1" =~ ^-{1,2}v(erbose)?$ ]]; then
      if [[ ${SUCCINCT} == 1 ]]; then
        Report_error "Cannot specify both -1 and -v"
        return 1
      fi
      VERBOSE=1
    elif [[ "$1" == "-1" ]]; then
      if [[ ${VERBOSE} == 1 ]]; then
        Report_error "Cannot specify both -1 and -v"
        return 1
      fi
      VERBOSE=0
      SUCCINCT=1
    elif [[ "$1" =~ ^-{1,2}p(latform)?$ ]]; then
      PLATFORM=1
    elif [[ "$1" =~ ^-{1,2}h(elp)?$ ]]; then
      Report_error "--help must be the only option"
      return 1
    elif [[ "$1" =~ ^-{1,2}version$ || "$1" == "-V" ]]; then
      Report_error "--version must be the only option"
      return 1
    else
      Report_error "Unknown option $1" 1>&2
      exit 1
    fi
    shift
  done

  Require_command "uname" || return 1
  KERNEL_OS="$(uname -s)" || {
    Report_error "Unable to determine the operating system with uname"
    return 1
  }
  OS="${KERNEL_OS}"

  # Validate every command needed by the selected path before producing output.
  if [[ ${VERBOSE} == 1 ]]; then
    if [[ "${KERNEL_OS}" == "Darwin" ]]; then
      Require_command "sw_vers" || return 1
    elif [[ -r /etc/os-release ]]; then
      Require_command "cat" || return 1
    fi
  elif [[ "${KERNEL_OS}" == "Linux" && -r /etc/os-release ]]; then
    Require_command "perl" || return 1
    OS="$(perl -lne 'if(m{^PRETTY_NAME="?([^"\n]+)"?$}){$os=$1;$os=~s{Oracle}{CentOS};print $os;}' /etc/os-release)" || {
      Report_error "Unable to determine the Linux distribution"
      return 1
    }
    if [[ -z "${OS}" ]]; then
      Report_error "Unable to determine the Linux distribution"
      return 1
    fi
  fi


  if [[ ${VERBOSE} == 0 ]]; then
    if [[ ${PLATFORM} == 1 ]]; then
      case "${OS}" in
        Darwin)
          OS="macOS"
          ;;
        MINGW*|MSYS*|CYGWIN*)
          OS="MinGW"
          ;;
        *)
          if [[ -r /cocalc/bin/cocalc-open ]]; then
            OS="cocalc"
          elif builtin command -V wsl.exe 1>/dev/null 2>&1; then
            OS="WSL"
          fi
          ;;
      esac
    fi
    if [[ ${SUCCINCT} == 1 ]]; then
      echo "${OS/ *}"
    else
      echo "${OS}"
    fi
    return
  fi

  Run_command uname -a
  case "${OS}" in
    Darwin)
      Run_command sw_vers
      ;;
    *)
      if [[ -r /etc/os-release ]]; then
        Run_command cat /etc/os-release
      fi
      ;;
  esac
}

Os_main "$@"
